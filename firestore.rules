rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'ADMIN'
      );
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'student';
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /credential_requests/{requestId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create, update: if false;
      allow delete: if false;
    }

    match /institutional_profiles/{profileEmail} {
      allow read: if isAdmin() || (
        signedIn() &&
        request.auth.token.email == profileEmail
      );
      allow write: if false;
    }

    match /credential_template_settings/{settingsId} {
      allow read, write: if isAdmin();
    }

    match /print_batches/{batchId} {
      allow read, write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin() || isOwner(resource.data.uid);
      allow write: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
