rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'ADMIN'
      );
    }

    function isPhoto(fileName) {
      return fileName.matches('photo-.*')
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png)');
    }

    function isEvidence(fileName) {
      return fileName.matches('evidence-.*')
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png)|application/pdf');
    }

    match /credential-requests/{uid}/{requestFolder}/{fileName} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn()
        && request.auth.uid == uid
        && (isPhoto(fileName) || isEvidence(fileName));
      allow update: if false;
      allow delete: if false;
    }
  }
}
